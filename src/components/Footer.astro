---
import Logo from "./Logo.astro";
import { site, navLinks, whatsappLink, whatsappMessages, tel } from "../data/site";
import { courses } from "../data/courses";

const year = new Date().getFullYear();
const waHref = whatsappLink(whatsappMessages.general);
---

<footer class="relative mt-24 overflow-hidden bg-teal-900 text-sand-100">
  <div class="pattern-dots pointer-events-none absolute inset-0 opacity-[0.06]"></div>

  <div class="container-x relative">
    <!-- CTA band -->
    <div
      class="-mt-12 mb-16 rounded-3xl bg-gradient-to-br from-teal-700 to-teal-800 px-6 py-10 shadow-lift ring-1 ring-white/10 sm:px-10 sm:py-12"
      data-reveal
    >
      <div class="flex flex-col items-center gap-6 text-center md:flex-row md:justify-between md:text-left">
        <div>
          <p class="font-serif text-2xl font-semibold text-white sm:text-3xl">
            Begin your Quran journey today
          </p>
          <p class="mt-2 max-w-xl text-sand-200/90">
            Book a free trial class and experience our teaching method before admission, with no obligation.
          </p>
        </div>
        <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
          <a
            href="/free-trial/"
            class="inline-flex items-center justify-center rounded-full bg-sand-50 px-6 py-3.5 font-semibold text-teal-800 shadow-soft transition-all hover:-translate-y-0.5 hover:bg-white"
          >
            Book Free Trial
          </a>
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-6 py-3.5 font-semibold text-white shadow-soft transition-all hover:-translate-y-0.5 hover:brightness-105"
          >
            <svg viewBox="0 0 24 24" class="size-5 fill-current" aria-hidden="true">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.78 14.06c-.24.67-1.42 1.31-1.95 1.36-.5.05-1.13.07-1.83-.11-.42-.14-.96-.32-1.66-.62-2.92-1.26-4.83-4.2-4.98-4.4-.14-.2-1.18-1.57-1.18-3 0-1.42.75-2.12 1.01-2.41.27-.29.58-.36.78-.36l.56.01c.18 0 .42-.07.65.5.24.59.82 2.02.89 2.16.07.14.12.31.02.51-.1.2-.15.31-.29.48l-.44.51c-.14.14-.29.3-.12.59.17.29.74 1.22 1.59 1.98 1.09.97 2.01 1.27 2.3 1.42.29.14.46.12.63-.07.17-.2.72-.84.91-1.13.19-.29.39-.24.65-.14.27.1 1.7.8 1.99.95.29.14.48.22.55.34.07.12.07.7-.17 1.37Z" />
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid gap-10 pb-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <Logo variant="light" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-sand-200/75">
          One-to-one live online Quran classes for kids &amp; adults. Learn from the
          comfort of home with proper Tajweed and sincere guidance.
        </p>
        <p class="mt-4 font-arabic text-xl text-gold-300">بِسْمِ اللَّٰهِ الرَّحْمَٰنِ الرَّحِيمِ</p>
      </div>

      <nav aria-label="Footer">
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-sand-300/80">
          Explore
        </h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sand-200/80 transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Courses">
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-sand-300/80">
          Courses
        </h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            courses.map((c) => (
              <li>
                <a
                  href={`/courses/#${c.slug}`}
                  class="text-sand-200/80 transition-colors hover:text-white"
                >
                  {c.title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-sand-300/80">
          Contact
        </h2>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a
              href={waHref}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sand-200/80 transition-colors hover:text-white"
            >
              WhatsApp chat
            </a>
          </li>
          <li>
            <a href={tel} class="text-sand-200/80 transition-colors hover:text-white">
              {site.phoneDisplay}
            </a>
          </li>
          <li class="text-sand-200/70">
            Flexible morning &amp; evening timings
          </li>
          <li class="text-sand-200/70">Free trial class available</li>
        </ul>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-3 border-t border-white/10 py-6 text-sm text-sand-200/60 sm:flex-row"
    >
      <p>© {year} {site.name}. All rights reserved.</p>
      <p class="text-sand-200/50">Online Quran Classes for Kids &amp; Adults</p>
    </div>
  </div>
</footer>
