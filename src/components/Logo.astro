---
import { site } from "../data/site";
interface Props {
  /** color scheme: 'default' on light, 'light' on dark backgrounds */
  variant?: "default" | "light";
  class?: string;
}
const { variant = "default", class: className = "" } = Astro.props;
const text = variant === "light" ? "text-sand-50" : "text-ink-900";
const sub = variant === "light" ? "text-sand-200/80" : "text-ink-500";
const markBg = variant === "light" ? "bg-sand-50/10" : "bg-teal-700";
const markStroke = variant === "light" ? "#faf6ee" : "#faf6ee";
---

<a
  href="/"
  class={`group inline-flex items-center gap-3 ${className}`}
  aria-label={`${site.name} home`}
>
  <span class={`grid size-10 shrink-0 place-items-center rounded-xl ${markBg} shadow-soft transition-transform duration-300 group-hover:scale-105`}>
    <svg width="22" height="22" viewBox="0 0 64 64" aria-hidden="true">
      <path
        d="M32 20c-4-2.6-9-3.4-14-2.4v23.8c5-1 10-.2 14 2.4 4-2.6 9-3.4 14-2.4V17.6c-5-1-10-.2-14 2.4Z"
        fill="none"
        stroke={markStroke}
        stroke-width="2.6"
        stroke-linejoin="round"
        stroke-linecap="round"></path>
      <path d="M32 20v23.8" stroke={markStroke} stroke-width="2.6" stroke-linecap="round"></path>
      <path d="M45.5 11.5a5.2 5.2 0 1 0 4.6 7.6 6.3 6.3 0 1 1-4.6-7.6Z" fill="#c9a86a"></path>
    </svg>
  </span>
  <span class="flex flex-col leading-none">
    <span class={`whitespace-nowrap font-serif text-[1.05rem] font-semibold tracking-tight ${text}`}>
      Hidaayah <span class="text-teal-500">Online</span>
    </span>
    <span class={`mt-0.5 whitespace-nowrap text-[0.66rem] font-medium uppercase tracking-[0.18em] ${sub}`}>
      Quran Academy
    </span>
  </span>
</a>
