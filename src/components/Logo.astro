---
import { site } from "../data/site";
import BrandMark from "./BrandMark.astro";
interface Props {
  /** color scheme: 'default' on light, 'light' on dark backgrounds */
  variant?: "default" | "light";
  class?: string;
}
const { variant = "default", class: className = "" } = Astro.props;
const text = variant === "light" ? "text-sand-50" : "text-ink-900";
const sub = variant === "light" ? "text-sand-200/80" : "text-ink-500";
---

<a
  href="/"
  class={`group inline-flex items-center gap-3 ${className}`}
  aria-label={`${site.name} home`}
>
  <BrandMark
    variant={variant}
    class="size-11 shrink-0 transition-transform duration-300 group-hover:scale-105"
  />
  <span class="flex flex-col leading-none">
    <span class={`whitespace-nowrap font-serif text-[1.2rem] font-semibold tracking-tight ${text}`}>
      {site.brand}
    </span>
    <span class={`mt-1 whitespace-nowrap text-[0.6rem] font-semibold uppercase tracking-[0.15em] ${sub}`}>
      {site.brandSub}
    </span>
  </span>
</a>
