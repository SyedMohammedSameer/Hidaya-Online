---
interface Props {
  id?: string;
  class?: string;
  /** vertical padding scale */
  pad?: "md" | "lg";
}
const { id, class: className = "", pad = "lg" } = Astro.props;
const padding = pad === "lg" ? "py-20 sm:py-24 lg:py-28" : "py-14 sm:py-16";
---

<section id={id} class={`${padding} ${className}`}>
  <div class="container-x">
    <slot />
  </div>
</section>
