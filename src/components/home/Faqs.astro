---
import SectionHeading from "../SectionHeading.astro";
import FaqAccordion from "../FaqAccordion.tsx";
import Button from "../Button.astro";
import { Icon } from "astro-icon/components";
import { faqs } from "../../data/faqs";
import { whatsappLink, whatsappMessages } from "../../data/site";

const waHref = whatsappLink(whatsappMessages.general);

// FAQ structured data for SEO
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section id="faqs" class="scroll-mt-24 bg-sand-100 py-20 sm:py-24 lg:py-28">
  <div class="container-x">
    <SectionHeading eyebrow="FAQs" title="Frequently asked questions">
      Everything you need to know before you begin. Still have a question? We’re a
      message away.
    </SectionHeading>

    <FaqAccordion client:visible faqs={faqs} />

    <div class="mt-10 flex flex-col items-center gap-3" data-reveal>
      <p class="text-ink-500">Still have questions?</p>
      <Button href={waHref} variant="secondary" external>
        <svg viewBox="0 0 24 24" class="size-4 fill-[#25D366]" aria-hidden="true">
          <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.78 14.06c-.24.67-1.42 1.31-1.95 1.36-.5.05-1.13.07-1.83-.11-.42-.14-.96-.32-1.66-.62-2.92-1.26-4.83-4.2-4.98-4.4-.14-.2-1.18-1.57-1.18-3 0-1.42.75-2.12 1.01-2.41.27-.29.58-.36.78-.36l.56.01c.18 0 .42-.07.65.5.24.59.82 2.02.89 2.16.07.14.12.31.02.51-.1.2-.15.31-.29.48l-.44.51c-.14.14-.29.3-.12.59.17.29.74 1.22 1.59 1.98 1.09.97 2.01 1.27 2.3 1.42.29.14.46.12.63-.07.17-.2.72-.84.91-1.13.19-.29.39-.24.65-.14.27.1 1.7.8 1.99.95.29.14.48.22.55.34.07.12.07.7-.17 1.37Z" />
        </svg>
        Chat with us on WhatsApp
      </Button>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
</section>
