---
import { Icon } from "astro-icon/components";
import Button from "../Button.astro";
import { whatsappLink, whatsappMessages } from "../../data/site";

const waHref = whatsappLink(whatsappMessages.trial);

const trialPoints = [
  "Student level assessment",
  "Introduction to our teaching method",
  "Basic guidance for course selection",
  "Flexible discussion about class timings",
];
---

<section id="free-trial" class="scroll-mt-24 py-20 sm:py-24 lg:py-28">
  <div class="container-x">
    <div
      class="relative overflow-hidden rounded-3xl bg-white shadow-lift ring-1 ring-teal-100"
      data-reveal
    >
      <div class="grid lg:grid-cols-2">
        <!-- Left -->
        <div class="p-8 sm:p-10 lg:p-12">
          <span class="eyebrow">
            <span class="h-px w-6 bg-teal-400"></span>
            Free Trial Class
          </span>
          <h2 class="mt-4 text-3xl font-semibold leading-tight text-balance sm:text-4xl">
            See how our classes work — before you enroll
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-ink-500">
            Start with a <strong class="font-semibold text-ink-900">free trial class</strong> and
            experience our teaching method first-hand. No payment, no obligation.
          </p>

          <ul class="mt-8 space-y-3.5">
            {
              trialPoints.map((p) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 grid size-6 shrink-0 place-items-center rounded-full bg-teal-100 text-teal-700">
                    <Icon name="lucide:check" class="size-4" />
                  </span>
                  <span class="text-ink-700">{p}</span>
                </li>
              ))
            }
          </ul>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row">
            <Button href="/free-trial/" size="lg">
              Book Free Trial Now
              <Icon name="lucide:arrow-right" class="size-4 transition-transform group-hover:translate-x-1" />
            </Button>
            <Button href={waHref} variant="secondary" size="lg" external>
              <svg viewBox="0 0 24 24" class="size-5 fill-[#25D366]" aria-hidden="true">
                <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.78 14.06c-.24.67-1.42 1.31-1.95 1.36-.5.05-1.13.07-1.83-.11-.42-.14-.96-.32-1.66-.62-2.92-1.26-4.83-4.2-4.98-4.4-.14-.2-1.18-1.57-1.18-3 0-1.42.75-2.12 1.01-2.41.27-.29.58-.36.78-.36l.56.01c.18 0 .42-.07.65.5.24.59.82 2.02.89 2.16.07.14.12.31.02.51-.1.2-.15.31-.29.48l-.44.51c-.14.14-.29.3-.12.59.17.29.74 1.22 1.59 1.98 1.09.97 2.01 1.27 2.3 1.42.29.14.46.12.63-.07.17-.2.72-.84.91-1.13.19-.29.39-.24.65-.14.27.1 1.7.8 1.99.95.29.14.48.22.55.34.07.12.07.7-.17 1.37Z" />
              </svg>
              Ask on WhatsApp
            </Button>
          </div>
        </div>

        <!-- Right visual -->
        <div class="relative flex items-center justify-center overflow-hidden bg-gradient-to-br from-teal-700 to-teal-900 p-8 sm:p-10 lg:p-12">
          <div class="pattern-dots absolute inset-0 opacity-[0.08]"></div>
          <div class="relative w-full max-w-sm">
            <div class="rounded-2xl bg-white/[0.07] p-6 ring-1 ring-inset ring-white/10 backdrop-blur-sm">
              <div class="flex items-center gap-3">
                <span class="grid size-12 place-items-center rounded-2xl bg-gold-400/20 text-gold-300 ring-1 ring-inset ring-gold-400/20">
                  <Icon name="lucide:gift" class="size-6" />
                </span>
                <div>
                  <p class="font-serif text-xl font-semibold text-white">100% Free</p>
                  <p class="text-sm text-sand-200/80">Trial class · no card needed</p>
                </div>
              </div>
              <div class="mt-6 space-y-3">
                <div class="flex items-center gap-2.5 text-sm text-sand-100">
                  <Icon name="lucide:clock" class="size-4 text-gold-300" /> Pick a time that suits you
                </div>
                <div class="flex items-center gap-2.5 text-sm text-sand-100">
                  <Icon name="lucide:monitor-smartphone" class="size-4 text-gold-300" /> Join from any device
                </div>
                <div class="flex items-center gap-2.5 text-sm text-sand-100">
                  <Icon name="lucide:message-circle" class="size-4 text-gold-300" /> Quick reply on WhatsApp
                </div>
              </div>
            </div>
            <p class="mt-6 text-center font-arabic text-2xl text-gold-300">
              وَقُل رَّبِّ زِدْنِي عِلْمًا
            </p>
            <p class="mt-1 text-center text-xs text-sand-200/70">
              “My Lord, increase me in knowledge.” · 20:114
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
