---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { site, whatsappLink, whatsappMessages, tel } from "../data/site";

const waHref = whatsappLink(whatsappMessages.general);

const fieldCls =
  "mt-1.5 w-full rounded-xl border-0 bg-sand-50 px-4 py-3 text-ink-900 shadow-sm ring-1 ring-inset ring-teal-200/70 transition placeholder:text-ink-500/60 focus:bg-white focus:ring-2 focus:ring-inset focus:ring-teal-500";
const labelCls = "block text-sm font-semibold text-ink-700";

const methods = [
  {
    icon: "lucide:message-circle",
    title: "WhatsApp",
    value: site.phoneDisplay,
    href: waHref,
    note: "Fastest way to reach us",
    external: true,
  },
  {
    icon: "lucide:phone",
    title: "Call us",
    value: site.phoneDisplay,
    href: tel,
    note: "During class hours",
    external: false,
  },
  {
    icon: "lucide:clock",
    title: "Class timings",
    value: "Morning & Evening",
    href: null,
    note: "Flexible by availability",
    external: false,
  },
];
---

<Layout
  title="Contact Us"
  description="Get in touch with Hidaayah Online Quran Academy. Message us on WhatsApp or send us a message to enroll yourself or your child in online Quran classes."
  path="/contact/"
>
  <PageHeader eyebrow="Contact Us" title="We'd love to hear from you" arabic="وَالسَّلَامُ عَلَيْكُمْ">
    Have a question, or ready to enroll yourself or your child? Reach out; we're
    happy to help and reply quickly.
  </PageHeader>

  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container-x">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.2fr] lg:gap-14">
        <!-- Methods -->
        <div data-reveal>
          <h2 class="font-serif text-2xl font-semibold text-ink-900">Ways to reach us</h2>
          <p class="mt-3 text-ink-500">
            Choose whatever is easiest for you. For the quickest reply, WhatsApp is best.
          </p>

          <div class="mt-7 space-y-4">
            {
              methods.map((m) => {
                const inner = (
                  <div class="flex items-center gap-4 rounded-2xl bg-white p-5 shadow-soft ring-1 ring-teal-100/70 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-lift">
                    <span class="grid size-12 shrink-0 place-items-center rounded-2xl bg-teal-50 text-teal-600">
                      <Icon name={m.icon} class="size-6" />
                    </span>
                    <div>
                      <p class="text-sm font-semibold uppercase tracking-wide text-ink-500">{m.title}</p>
                      <p class="text-lg font-semibold text-ink-900">{m.value}</p>
                      <p class="text-sm text-ink-500">{m.note}</p>
                    </div>
                  </div>
                );
                return m.href ? (
                  <a
                    href={m.href}
                    class="group block"
                    target={m.external ? "_blank" : undefined}
                    rel={m.external ? "noopener noreferrer" : undefined}
                  >
                    {inner}
                  </a>
                ) : (
                  <div class="group">{inner}</div>
                );
              })
            }
          </div>

          <div class="mt-6 rounded-2xl bg-teal-900 p-6 text-sand-100">
            <p class="font-arabic text-2xl text-gold-300">طَلَبُ الْعِلْمِ فَرِيضَةٌ</p>
            <p class="mt-2 text-sm text-sand-200/80">
              “Seeking knowledge is an obligation upon every Muslim.”
            </p>
          </div>
        </div>

        <!-- Form -->
        <div
          class="rounded-3xl bg-white p-6 shadow-lift ring-1 ring-teal-100 sm:p-8 lg:p-10"
          data-reveal
          data-reveal-delay="80"
        >
          <h2 class="font-serif text-2xl font-semibold text-ink-900">Send us a message</h2>
          <p class="mt-2 text-ink-500">We'll get back to you as soon as we can.</p>

          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/thank-you/"
            class="mt-6 grid gap-5"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class={labelCls} for="c-name">Full name <span class="text-teal-600">*</span></label>
                <input class={fieldCls} type="text" id="c-name" name="name" required autocomplete="name" placeholder="Your name" />
              </div>
              <div>
                <label class={labelCls} for="c-phone">Phone / WhatsApp <span class="text-teal-600">*</span></label>
                <input class={fieldCls} type="tel" id="c-phone" name="phone" required autocomplete="tel" placeholder="+91 …" />
              </div>
            </div>

            <div>
              <label class={labelCls} for="c-email">Email <span class="font-normal text-ink-500">(optional)</span></label>
              <input class={fieldCls} type="email" id="c-email" name="email" autocomplete="email" placeholder="you@example.com" />
            </div>

            <div>
              <label class={labelCls} for="c-message">Message <span class="text-teal-600">*</span></label>
              <textarea class={fieldCls} id="c-message" name="message" rows="5" required placeholder="How can we help you?"></textarea>
            </div>

            <button
              type="submit"
              class="group inline-flex w-full items-center justify-center gap-2 rounded-full bg-teal-700 px-7 py-3.5 font-semibold text-sand-50 shadow-soft transition-all duration-300 hover:-translate-y-0.5 hover:bg-teal-800 hover:shadow-lift sm:w-auto"
            >
              Send message
              <Icon name="lucide:send" class="size-4 transition-transform group-hover:translate-x-1" />
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
