---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";
import { courses } from "../data/courses";
import { courseIcon } from "../data/icons";
import { whatsappLink, whatsappMessages } from "../data/site";

const waHref = whatsappLink(whatsappMessages.general);
---

<Layout
  title="Courses"
  description="Explore our online Quran courses: Noorani Qaida, Quran Reading, Tajweed, Hifz, Salah & Duas, and Basic Islamic Studies. One-to-one live classes for all levels."
  path="/courses/"
>
  <PageHeader eyebrow="Our Courses" title="Online Quran courses for every level" arabic="﴿وَرَتِّلِ الْقُرْآنَ تَرْتِيلًا﴾">
    From your first Arabic letter to complete Hifz: structured, one-to-one courses
    taught with proper Tajweed and sincere care.
  </PageHeader>

  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container-x">
      <div class="space-y-6">
        {
          courses.map((course, i) => (
            <article
              id={course.slug}
              class="scroll-mt-28 overflow-hidden rounded-3xl bg-white shadow-soft ring-1 ring-teal-100/70"
              data-reveal
            >
              <div class="grid gap-0 lg:grid-cols-[1fr_1.4fr]">
                <!-- left accent -->
                <div class="relative flex flex-col justify-between gap-6 bg-gradient-to-br from-teal-700 to-teal-900 p-7 text-sand-100 sm:p-9">
                  <div class="pattern-dots absolute inset-0 opacity-[0.07]" />
                  <div class="relative">
                    <div class="flex items-center justify-between">
                      <span class="grid size-14 place-items-center rounded-2xl bg-white/10 text-sand-50 ring-1 ring-inset ring-white/15">
                        <Icon name={courseIcon[course.icon] ?? "lucide:book-open"} class="size-7" />
                      </span>
                      <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-sand-100 ring-1 ring-inset ring-white/15">
                        {course.level}
                      </span>
                    </div>
                    <h2 class="mt-5 text-2xl font-semibold text-white">{course.title}</h2>
                    {course.titleArabic && (
                      <p class="mt-1 font-arabic text-2xl text-gold-300">{course.titleArabic}</p>
                    )}
                  </div>
                  <p class="relative text-sm leading-relaxed text-sand-200/85">
                    {course.summary}
                  </p>
                </div>

                <!-- right details -->
                <div class="p-7 sm:p-9">
                  <p class="text-base leading-relaxed text-ink-700">
                    {course.details}
                  </p>
                  <h3 class="mt-6 text-sm font-semibold uppercase tracking-wider text-teal-700">
                    What you'll learn
                  </h3>
                  <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                    {course.points.map((p) => (
                      <li class="flex items-start gap-2.5">
                        <span class="mt-0.5 grid size-5 shrink-0 place-items-center rounded-full bg-teal-100 text-teal-700">
                          <Icon name="lucide:check" class="size-3.5" />
                        </span>
                        <span class="text-sm text-ink-700">{p}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="mt-7 flex flex-wrap gap-3">
                    <Button href="/free-trial/">
                      Book Free Trial
                      <Icon name="lucide:arrow-right" class="size-4 transition-transform group-hover:translate-x-1" />
                    </Button>
                    <Button href={waHref} variant="ghost" external>
                      Ask about this course
                    </Button>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <!-- bottom CTA -->
      <div class="mt-14 rounded-3xl bg-teal-50 p-8 text-center ring-1 ring-teal-100 sm:p-10" data-reveal>
        <h2 class="text-2xl font-semibold text-ink-900 sm:text-3xl">Not sure which course to start with?</h2>
        <p class="mx-auto mt-3 max-w-xl text-ink-500">
          Book a free trial and we'll assess your level and recommend the right
          starting point for you or your child.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <Button href="/free-trial/" size="lg">Book Free Trial</Button>
          <Button href="/fee-plans/" variant="secondary" size="lg">View fee plan</Button>
        </div>
      </div>
    </div>
  </section>
</Layout>
