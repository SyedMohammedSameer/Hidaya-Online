---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";
import { whatsappLink, whatsappMessages } from "../data/site";

const waHref = whatsappLink(whatsappMessages.fees);

const included = [
  "One-to-one live online classes",
  "Choose any course: Qaida, Quran, Tajweed, Hifz & more",
  "Flexible morning & evening timings",
  "Personalized teaching at your own pace",
  "Caring, structured guidance",
  "Suitable for kids, teenagers & adults",
];
---

<Layout
  title="Fees"
  description="Affordable, flexible fees for one-to-one online Quran classes. Reach out and we'll recommend a plan tailored to you, with a free trial before you enroll."
  path="/fee-plans/"
>
  <PageHeader eyebrow="Fees" title="Affordable & tailored to you">
    We keep our classes accessible, with flexible fees based on your course and
    schedule. Reach out and we'll suggest the best plan for you, no obligation.
  </PageHeader>

  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container-x">
      <div class="mx-auto max-w-lg" data-reveal>
        <div class="relative overflow-hidden rounded-3xl bg-white shadow-lift ring-1 ring-teal-100">
          <!-- top band -->
          <div class="relative overflow-hidden bg-gradient-to-br from-teal-700 to-teal-900 px-8 py-10 text-center text-sand-100">
            <div class="pattern-dots absolute inset-0 opacity-[0.08]"></div>
            <div class="relative">
              <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-sand-100 ring-1 ring-inset ring-white/15">
                Personalized Plans
              </span>
              <p class="mt-6 font-serif text-3xl font-semibold leading-tight text-white sm:text-4xl">
                Let's find the right<br />plan for you
              </p>
              <p class="mt-4 text-sm text-sand-200/85">
                Fees depend on your chosen course and the number of classes per
                week. Message us and we'll share the details.
              </p>
            </div>
          </div>

          <!-- body -->
          <div class="px-8 py-8">
            <p class="text-sm font-semibold uppercase tracking-wider text-teal-700">
              Every plan includes
            </p>
            <ul class="mt-4 space-y-3.5">
              {
                included.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 grid size-6 shrink-0 place-items-center rounded-full bg-teal-100 text-teal-700">
                      <Icon name="lucide:check" class="size-4" />
                    </span>
                    <span class="text-ink-700">{item}</span>
                  </li>
                ))
              }
            </ul>

            <div class="mt-8 flex flex-col gap-3">
              <Button href={waHref} variant="whatsapp" size="lg" class="w-full" external>
                <svg viewBox="0 0 24 24" class="size-5 fill-current" aria-hidden="true">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.78 14.06c-.24.67-1.42 1.31-1.95 1.36-.5.05-1.13.07-1.83-.11-.42-.14-.96-.32-1.66-.62-2.92-1.26-4.83-4.2-4.98-4.4-.14-.2-1.18-1.57-1.18-3 0-1.42.75-2.12 1.01-2.41.27-.29.58-.36.78-.36l.56.01c.18 0 .42-.07.65.5.24.59.82 2.02.89 2.16.07.14.12.31.02.51-.1.2-.15.31-.29.48l-.44.51c-.14.14-.29.3-.12.59.17.29.74 1.22 1.59 1.98 1.09.97 2.01 1.27 2.3 1.42.29.14.46.12.63-.07.17-.2.72-.84.91-1.13.19-.29.39-.24.65-.14.27.1 1.7.8 1.99.95.29.14.48.22.55.34.07.12.07.7-.17 1.37Z" />
                </svg>
                Reach out to discuss fees
              </Button>
              <Button href="/free-trial/" variant="secondary" size="lg" class="w-full">
                Start with a free trial
                <Icon name="lucide:arrow-right" class="size-4 transition-transform group-hover:translate-x-1" />
              </Button>
            </div>
          </div>
        </div>

        <p class="mt-6 text-center text-sm text-ink-500">
          <Icon name="lucide:info" class="mr-1 inline size-4 align-text-bottom text-teal-500" />
          Try a free trial class first, then choose a plan that fits your needs and budget.
        </p>
      </div>

      <!-- reassurance row -->
      <div class="mx-auto mt-14 grid max-w-3xl gap-4 sm:grid-cols-3">
        {
          [
            { icon: "lucide:gift", title: "Free trial", text: "Try before you commit" },
            { icon: "lucide:shield-check", title: "No hidden fees", text: "Clear & honest" },
            { icon: "lucide:calendar-clock", title: "Flexible", text: "Plans that suit you" },
          ].map((f, i) => (
            <div
              class="rounded-2xl bg-sand-100 p-5 text-center ring-1 ring-teal-100/60"
              data-reveal
              data-reveal-delay={i * 80}
            >
              <span class="mx-auto grid size-11 place-items-center rounded-xl bg-white text-teal-600 shadow-soft">
                <Icon name={f.icon} class="size-5" />
              </span>
              <h3 class="mt-3 font-semibold text-ink-900">{f.title}</h3>
              <p class="mt-0.5 text-sm text-ink-500">{f.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
