---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";
import { site, whatsappLink, whatsappMessages } from "../data/site";

const waHref = whatsappLink(whatsappMessages.general);

const included = [
  "One-to-one live online classes",
  "Choose any course: Qaida, Quran, Tajweed, Hifz & more",
  "Flexible morning & evening timings",
  "Personalized teaching at your own pace",
  "Caring, structured guidance",
  "Suitable for kids, teenagers & adults",
];
---

<Layout
  title="Fee Plans"
  description={`Simple, affordable Quran classes from ${site.fee.currency}${site.fee.amount} per ${site.fee.period}. One-to-one live online classes with a free trial before you enroll.`}
  path="/fee-plans/"
>
  <PageHeader eyebrow="Fee Plans" title="Simple, affordable & transparent">
    One clear plan, no hidden charges. Start with a free trial and pay only when
    you're ready to enroll.
  </PageHeader>

  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container-x">
      <div class="mx-auto max-w-lg" data-reveal>
        <div class="relative overflow-hidden rounded-3xl bg-white shadow-lift ring-1 ring-teal-100">
          <!-- top band -->
          <div class="relative overflow-hidden bg-gradient-to-br from-teal-700 to-teal-900 px-8 py-10 text-center text-sand-100">
            <div class="pattern-dots absolute inset-0 opacity-[0.08]"></div>
            <div class="relative">
              <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-sand-100 ring-1 ring-inset ring-white/15">
                Monthly Plan
              </span>
              <div class="mt-6 flex items-end justify-center gap-1">
                <span class="font-serif text-3xl font-semibold text-gold-300">{site.fee.currency}</span>
                <span class="font-serif text-6xl font-semibold leading-none text-white">{site.fee.amount}</span>
                <span class="mb-1.5 text-lg text-sand-200/80">/ {site.fee.period}</span>
              </div>
              <p class="mt-3 text-sm text-sand-200/80">Per student · billed monthly</p>
            </div>
          </div>

          <!-- body -->
          <div class="px-8 py-8">
            <ul class="space-y-3.5">
              {
                included.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 grid size-6 shrink-0 place-items-center rounded-full bg-teal-100 text-teal-700">
                      <Icon name="lucide:check" class="size-4" />
                    </span>
                    <span class="text-ink-700">{item}</span>
                  </li>
                ))
              }
            </ul>

            <div class="mt-8 flex flex-col gap-3">
              <Button href="/free-trial/" size="lg" class="w-full">
                Start with a Free Trial
                <Icon name="lucide:arrow-right" class="size-4 transition-transform group-hover:translate-x-1" />
              </Button>
              <Button href={waHref} variant="secondary" size="lg" class="w-full" external>
                Discuss on WhatsApp
              </Button>
            </div>
          </div>
        </div>

        <p class="mt-6 text-center text-sm text-ink-500">
          <Icon name="lucide:info" class="mr-1 inline size-4 align-text-bottom text-teal-500" />
          Fees may vary based on the number of classes per week and course.
          Message us for a plan tailored to your needs.
        </p>
      </div>

      <!-- reassurance row -->
      <div class="mx-auto mt-14 grid max-w-3xl gap-4 sm:grid-cols-3">
        {
          [
            { icon: "lucide:gift", title: "Free trial", text: "Try before you pay" },
            { icon: "lucide:shield-check", title: "No hidden fees", text: "Clear & honest pricing" },
            { icon: "lucide:calendar-clock", title: "Flexible", text: "Timings that suit you" },
          ].map((f, i) => (
            <div
              class="rounded-2xl bg-sand-100 p-5 text-center ring-1 ring-teal-100/60"
              data-reveal
              data-reveal-delay={i * 80}
            >
              <span class="mx-auto grid size-11 place-items-center rounded-xl bg-white text-teal-600 shadow-soft">
                <Icon name={f.icon} class="size-5" />
              </span>
              <h3 class="mt-3 font-semibold text-ink-900">{f.title}</h3>
              <p class="mt-0.5 text-sm text-ink-500">{f.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
